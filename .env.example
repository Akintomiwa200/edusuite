# ══════════════════════════════════════════════════════════════════
#  EduSuite 2.0 — Environment Variables
#  Copy this file to .env and fill in all values
# ══════════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=EduSuite
PORT=4000
API_PREFIX=api
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── MongoDB ────────────────────────────────────────────────────────
# Production: Use MongoDB Atlas
# Development: Docker compose
MONGODB_URI=mongodb://edusuite:edusuite_dev_pass@localhost:27017
DB_NAME=edusuite
MONGO_ROOT_USER=edusuite
MONGO_ROOT_PASSWORD=edusuite_dev_pass

# ── Redis ──────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_pass
REDIS_TTL=3600

# ── RabbitMQ ───────────────────────────────────────────────────────
RABBITMQ_URL=amqp://edusuite:rabbitmq_dev_pass@localhost:5672/edusuite
RABBITMQ_USER=edusuite
RABBITMQ_PASS=rabbitmq_dev_pass

# ── JWT Auth ───────────────────────────────────────────────────────
# IMPORTANT: Generate strong secrets for production!
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-very-long-random-string-in-production
JWT_REFRESH_SECRET=change-me-to-another-very-long-random-string-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Cloudinary (Primary File Storage) ─────────────────────────────
# Sign up at https://cloudinary.com and create a project
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Cloudinary Upload Preset (for client-side uploads)
CLOUDINARY_UPLOAD_PRESET=edusuite-uploads

# ── OpenAI (AI Features) ───────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# ── WebRTC / Mediasoup ─────────────────────────────────────────────
# Set this to your server's PUBLIC IP address
WEBRTC_PUBLIC_IP=127.0.0.1
WEBRTC_MIN_PORT=40000
WEBRTC_MAX_PORT=49999

# ── Email (SMTP) ───────────────────────────────────────────────────
# Development: Use MailHog (smtp://localhost:1025)
# Production: Use SendGrid, Mailgun, AWS SES, etc.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@edusuite.com
SMTP_FROM_NAME=EduSuite

# ── SMS (Twilio) ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Payment Gateways ───────────────────────────────────────────────
# Paystack
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# Flutterwave
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_flutterwave_secret
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_flutterwave_public
FLUTTERWAVE_ENCRYPTION_KEY=your_flutterwave_encryption_key

# ── Firebase (Push Notifications) ─────────────────────────────────
# Download google-services.json from Firebase Console
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ── Rate Limiting ──────────────────────────────────────────────────
RATE_LIMIT_SHORT=10
RATE_LIMIT_MEDIUM=50
RATE_LIMIT_LONG=200

# ── Frontend (Next.js) ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WEBRTC_URL=http://localhost:4000
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_APP_NAME=EduSuite
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key

# ── Mobile (Expo) ──────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1
EXPO_PUBLIC_WEBRTC_URL=http://localhost:4000
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
EAS_PROJECT_ID=your-eas-project-id

# ── Monitoring ─────────────────────────────────────────────────────
PROMETHEUS_ENABLED=true
GRAFANA_URL=http://localhost:3000
SENTRY_DSN=https://your-sentry-dsn@o123456.ingest.sentry.io/123456
